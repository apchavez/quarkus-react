# Copy to terraform.tfvars and adjust as needed.
# terraform.tfvars is gitignored — never commit real values here.

aws_region   = "us-east-1"
cluster_name = "product-management"

# Cost knobs — see terraform/README.md for an estimate before applying.
# t3.small (not t3.medium): this AWS account is on the restrictive Free Plan,
# which hard-rejects EC2 launches for any instance type not tagged
# free-tier-eligible (verify with `aws ec2 describe-instance-types
# --filters Name=free-tier-eligible,Values=true`) — confirmed the hard way
# when a t3.medium node group failed with InvalidParameterCombination.
node_instance_types = ["t3.small"]
node_min_size       = 1
node_max_size       = 2
node_desired_size   = 2
